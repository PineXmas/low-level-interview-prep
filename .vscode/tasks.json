{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build all problems",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "for d in ${workspaceFolder}/problems/*/; do if [ -f \"$d/Makefile\" ]; then echo Building $d; (cd \"$d\" && make); fi; done"],
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
